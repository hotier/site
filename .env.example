# Sveltia CMS GitHub OAuth Configuration
# Copy this file to .env.local and fill in your GitHub OAuth credentials

# GitHub OAuth App Credentials
# Create a new OAuth App at: https://github.com/settings/applications/new
# Authorization callback URL: https://hotier.cc.cd/api/callback
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here

# Allowed domains for CORS (comma-separated)
# Use * to allow all domains (not recommended for production)
ALLOWED_DOMAINS=hotier.cc.cd,www.hotier.cc.cd
